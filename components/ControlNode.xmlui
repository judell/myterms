<Component name="ControlNode">
  <Button
    label="Delegate"
    when="{phase === 0}"
    onClick="delegate()" />
  <Button
    label="Lookup"
    when="{phase === 1 && !pulse.active}"
    onClick="getTerms()" />
  <Button
    label="Proffer"
    when="{phase === 4}"
    onClick="proffer()" />
  <Button
    label="Apply Policy"
    when="{phase === 6}"
    onClick="applyPolicy()" />
</Component>
