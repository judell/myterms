<Component name="EntityAgentNode">
  <ModalDialog id="eaHelp" title="Kleindorfer's Agent">
    <Text>A software agent that acts on behalf of the entity to negotiate and record agreements.</Text>
  </ModalDialog>
  <ModalDialog id="eaMagnet" title="Kleindorfer's Agent Terms">
    <Text>This magnet represents the entity agent acceptance criteria. When attracted, it confirms the entity willingness to bind to the offered terms.</Text>
  </ModalDialog>
  <VStack gap="$space-1" padding="$space-2">
    <HStack verticalAlignment="center">
      <Text fontSize="2rem" color="$color-primary" cursor="pointer" onClick="eaMagnet.open()">⊃</Text>
      <Text fontWeight="bold" fontSize="$fontSize-small">Kleindorfer's Agent</Text>
    </HStack>
    <Text fontSize="$fontSize-small" color="$textColor-secondary" when="{offeredTerm === '' || pulseNotReached('proffers')}">No term offered yet</Text>
    <Text fontSize="$fontSize-small" fontWeight="bold" color="$color-success" when="{offeredTerm !== '' && pulseReached('proffers') && lookupTermPolicy(offeredTerm) === 'Accept'}">Accepted: {offeredTerm}</Text>
    <Text fontSize="$fontSize-small" fontWeight="bold" color="$color-danger" when="{offeredTerm !== '' && pulseReached('proffers') && lookupTermPolicy(offeredTerm) === 'Reject'}">Rejected: {offeredTerm}</Text>
  </VStack>
</Component>
